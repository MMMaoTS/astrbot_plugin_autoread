{
  "Basic_Settings": {
    "type": "object",
    "description": "基础设置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用阅读",
        "default": true
      },
      "default_interval_minutes": {
        "type": "int",
        "description": "阅读间隔",
        "hint": "单位：分钟。",
        "default": 1440
      },
      "worker_tick_seconds": {
        "type": "int",
        "description": "后台检查间隔",
        "hint": "单位：秒。",
        "default": 60
      },
      "auto_share_mode": {
        "type": "string",
        "description": "分享方式",
        "options": ["none", "daily", "chapter", "every_step", "finish"],
        "default": "chapter"
      },
      "enable_llm_tools": {
        "type": "bool",
        "description": "启用对话工具",
        "default": true
      },
      "allow_llm_read_next": {
        "type": "bool",
        "description": "允许模型主动推进",
        "default": true
      },
      "enable_role_expr_command_query": {
        "type": "bool",
        "description": "命令查询类 LLM 表达",
        "hint": "控制 /read status、/read list、/read progress 等命令查询类输出是否允许通过 LLM 进行临时角色化表达。默认关闭。开启后可能增加 token 消耗，需关注记忆插件是否采集命令类回复。当前处于验证阶段，建议仅在测试环境中开启。",
        "default": false
      },
      "enable_role_expr_read_action": {
        "type": "bool",
        "description": "命令型阅读动作 LLM 表达",
        "hint": "控制 /read step、/read reread 等命令型阅读动作是否允许通过 LLM 进行角色化表达。默认关闭。当前处于验证阶段，不应在未完成验证前开启。",
        "default": false
      },
      "enable_role_expr_notes": {
        "type": "bool",
        "description": "笔记类 LLM 表达",
        "hint": "控制读书笔记/摘要类内容是否允许通过 LLM 进行角色化表达。默认关闭。开启前需确认笔记生成与记忆边界。",
        "default": false
      },
      "enable_role_expr_worker_share": {
        "type": "bool",
        "description": "Worker 主动分享 LLM 表达",
        "hint": "控制 Worker 主动分享是否允许通过 LLM 进行角色化表达。默认关闭。开启前需确认平台流水、短期历史与长期记忆边界。",
        "default": false
      },
      "enable_role_expr_natural_chat": {
        "type": "bool",
        "description": "自然语言交互角色表达",
        "hint": "控制自然语言读书交互是否允许角色表达。默认开启。不等于自动写入长期记忆，记忆是否写入仍由记忆插件策略决定。",
        "default": true
      },
      "enabled_umos": {
        "type": "list",
        "description": "启用自然读书能力的 UMO 列表",
        "hint": "仅列表中的会话/对象会启用自然语言读书能力（LLM Tool 等）。留空表示不启用自然化能力；/read 兜底命令不受此限制，仍可用于手动管理和调试。UMO 是能力生效范围，不是书籍所有权边界。多个 UMO 以逗号或换行分隔。",
        "default": []
      },
      "auto_import_uploaded_books": {
        "type": "bool",
        "description": "上传文件自动入库",
        "hint": "开启后，在启用了自然读书能力的会话中上传支持的书籍文件（txt/md）时，自动导入到角色书架。默认关闭。导入后默认不主动回复。需 enabled_umos 同时命中才生效。属于书架更新事件，不是对话回复事件。",
        "default": false
      }
    }
  },
  "Reading_Settings": {
    "type": "object",
    "description": "阅读设置",
    "items": {
      "chunk_size": {
        "type": "int",
        "description": "切片长度",
        "hint": "每次阅读最大字符数。",
        "default": 1800
      },
      "chunk_overlap": {
        "type": "int",
        "description": "切片重叠",
        "hint": "相邻切片重叠字符数。",
        "default": 120
      },
      "reading_persona_prompt": {
        "type": "text",
        "description": "阅读提示词",
        "default": "你正在以当前人格身份进行持续阅读。这不是临时检索、问答总结或资料查询，而是属于你自己的阶段性阅读经历。请保持当前人格设定、称呼习惯、表达气质和情绪反应方式，像真实读者一样记录你实际读到这里时的理解、细节注意、疑问、情绪和观点变化。只能基于本次实际读到的文本片段写笔记，不要假装读过后文或整本书，不要编造剧情、主题、作者意图或人物关系。如果信息不足，应诚实记录「目前还不足以判断」。笔记应体现持续阅读的进度感：你只是读到了这里，后续理解可以随着继续阅读而改变。"
      },
      "max_notes_per_book": {
        "type": "int",
        "description": "笔记上限",
        "default": 200
      },
      "allow_url_import": {
        "type": "bool",
        "description": "链接导入",
        "default": false
      },
      "allowed_extensions": {
        "type": "list",
        "description": "允许导入的扩展名",
        "default": [".txt", ".md"]
      },
      "memory_backend": {
        "type": "string",
        "description": "记忆后端",
        "options": ["none", "angel_memory", "livingmemory"],
        "default": "none"
      }
    }
  },
  "Model_Settings": {
    "type": "object",
    "description": "模型设置",
    "items": {
      "model_strategy": {
        "type": "string",
        "description": "模型策略",
        "options": ["current_session", "single", "dual"],
        "labels": ["当前会话", "单模型", "双模型"],
        "default": "dual"
      },
      "reader_provider_id": {
        "type": "string",
        "description": "阅读模型",
        "hint": "用于日常阅读和片段笔记。",
        "_special": "select_provider",
        "default": ""
      },
      "thinker_provider_id": {
        "type": "string",
        "description": "思考模型",
        "hint": "用于总结、复核和重要看法。",
        "_special": "select_provider",
        "default": ""
      },
      "single_provider_id": {
        "type": "string",
        "description": "单模型",
        "hint": "单模型策略下使用。",
        "_special": "select_provider",
        "default": ""
      },
      "enable_stage_routing": {
        "type": "bool",
        "description": "自定义阶段模型",
        "hint": "开启后可为各阅读阶段单独选择模型。",
        "default": false
      },
      "stage_chunk_note_provider_id": {
        "type": "string",
        "description": "片段阅读模型",
        "hint": "仅在自定义阶段模型开启时生效。留空则使用阅读模型。",
        "_special": "select_provider",
        "default": ""
      },
      "stage_chunk_review_provider_id": {
        "type": "string",
        "description": "片段复核模型",
        "hint": "仅在自定义阶段模型开启时生效。留空则使用思考模型。",
        "_special": "select_provider",
        "default": ""
      },
      "stage_chapter_note_provider_id": {
        "type": "string",
        "description": "章节总结模型",
        "hint": "仅在自定义阶段模型开启时生效。留空则使用思考模型。",
        "_special": "select_provider",
        "default": ""
      },
      "stage_final_review_provider_id": {
        "type": "string",
        "description": "全书总结模型",
        "hint": "仅在自定义阶段模型开启时生效。留空则使用思考模型。",
        "_special": "select_provider",
        "default": ""
      },
      "stage_memory_note_provider_id": {
        "type": "string",
        "description": "记忆沉淀模型",
        "hint": "仅在自定义阶段模型开启时生效。留空则使用思考模型。",
        "_special": "select_provider",
        "default": ""
      },
      "stage_user_share_provider_id": {
        "type": "string",
        "description": "重要分享模型",
        "hint": "仅在自定义阶段模型开启时生效。留空则使用思考模型。",
        "_special": "select_provider",
        "default": ""
      },
      "enable_deeper_review": {
        "type": "bool",
        "description": "深入复核",
        "hint": "重要片段使用复核模型再读一次。",
        "default": true
      },
      "importance_threshold": {
        "type": "float",
        "description": "重要性阈值",
        "hint": "超过该分数后触发复核。",
        "default": 0.75
      },
      "max_reviews_per_chapter": {
        "type": "int",
        "description": "每章复核上限",
        "hint": "限制每章最多复核次数。",
        "default": 3
      }
    }
  },
  "WebUI_Settings": {
    "type": "object",
    "description": "页面设置",
    "items": {
      "webui_enabled": {
        "type": "bool",
        "description": "启用页面",
        "default": true
      },
      "webui_upload_enabled": {
        "type": "bool",
        "description": "允许上传",
        "default": true
      },
      "webui_max_upload_mb": {
        "type": "int",
        "description": "上传上限",
        "hint": "单位：MB。",
        "default": 10
      },
      "webui_delete_enabled": {
        "type": "bool",
        "description": "允许 WebUI 删除数据",
        "hint": "开启后允许在 WebUI 中删除书籍和笔记。属于危险操作，请谨慎开启。",
        "default": false
      },
      "webui_last_error_ttl_minutes": {
        "type": "int",
        "description": "错误显示时长",
        "hint": "最后错误在 WebUI 中保留的分钟数，过期后自动隐藏。最小 1 分钟。",
        "default": 30
      },
      "webui_allow_book_delete": {
        "type": "bool",
        "description": "允许删除书籍（已弃用，请使用 webui_delete_enabled）",
        "default": false
      },
      "webui_notes_export_enabled": {
        "type": "bool",
        "description": "允许导出笔记",
        "default": true
      }
    }
  }
}
