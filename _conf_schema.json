{
  "enabled": {
    "description": "启用自主阅读。",
    "type": "bool",
    "default": true
  },
  "enable_llm_tools": {
    "description": "启用自然对话工具入口。",
    "type": "bool",
    "default": true
  },
  "allow_llm_read_next": {
    "description": "允许模型在对话中主动推进阅读。",
    "type": "bool",
    "default": true
  },
  "max_tool_read_steps_per_turn": {
    "description": "单轮对话最多推进次数。",
    "type": "int",
    "default": 1
  },
  "default_interval_minutes": {
    "description": "默认阅读间隔，单位分钟。",
    "type": "int",
    "default": 1440
  },
  "worker_tick_seconds": {
    "description": "后台检查间隔，单位秒。",
    "type": "int",
    "default": 60
  },
  "chunk_size": {
    "description": "每次阅读最大字符数。",
    "type": "int",
    "default": 1800
  },
  "chunk_overlap": {
    "description": "相邻切片重叠字符数。",
    "type": "int",
    "default": 120
  },
  "max_notes_per_book": {
    "description": "每本书最多保留笔记数。",
    "type": "int",
    "default": 200
  },
  "auto_share_mode": {
    "description": "主动分享方式。",
    "type": "string",
    "options": ["none", "daily", "chapter", "every_step", "finish"],
    "default": "chapter"
  },
  "allow_url_import": {
    "description": "允许从链接导入文本。",
    "type": "bool",
    "default": false
  },
  "allowed_extensions": {
    "description": "允许导入的文件扩展名。",
    "type": "list",
    "default": [".txt", ".md"]
  },
  "memory_backend": {
    "description": "长期记忆后端。",
    "type": "string",
    "options": ["none", "angel_memory", "livingmemory"],
    "default": "none"
  },
  "reading_persona_prompt": {
    "description": "阅读笔记提示词。",
    "type": "text",
    "default": "你正在以当前人格身份进行持续阅读。这不是临时检索、问答总结或资料查询，而是属于你自己的阶段性阅读经历。请保持当前人格设定、称呼习惯、表达气质和情绪反应方式，像真实读者一样记录你实际读到这里时的理解、细节注意、疑问、情绪和观点变化。只能基于本次实际读到的文本片段写笔记，不要假装读过后文或整本书，不要编造剧情、主题、作者意图或人物关系。如果信息不足，应诚实记录「目前还不足以判断」。笔记应体现持续阅读的进度感：你只是读到了这里，后续理解可以随着继续阅读而改变。"
  },
  "reading_model_mode": {
    "description": "（旧）模型选择策略。",
    "type": "string",
    "options": ["current_session", "fixed_provider", "default"],
    "default": "current_session"
  },
  "reading_provider_id": {
    "description": "（旧）固定模型。",
    "type": "string",
    "default": ""
  },
  "reading_provider_display_name": {
    "description": "（旧）固定模型名称。",
    "type": "string",
    "default": ""
  },
  "fallback_to_current_session_provider": {
    "description": "模型不可用时回退到当前会话。",
    "type": "bool",
    "default": true
  },
  "reading_model_strategy": {
    "description": "阅读模型分工方式。",
    "type": "string",
    "options": ["current_session", "fixed_single", "two_stage"],
    "default": "two_stage"
  },
  "cheap_provider_id": {
    "description": "低成本模型。",
    "type": "string",
    "default": ""
  },
  "cheap_provider_display_name": {
    "description": "低成本模型名称。",
    "type": "string",
    "default": ""
  },
  "quality_provider_id": {
    "description": "高质量模型。",
    "type": "string",
    "default": ""
  },
  "quality_provider_display_name": {
    "description": "高质量模型名称。",
    "type": "string",
    "default": ""
  },
  "single_provider_id": {
    "description": "单模型模式使用的模型。",
    "type": "string",
    "default": ""
  },
  "single_provider_display_name": {
    "description": "单模型名称。",
    "type": "string",
    "default": ""
  },
  "chunk_note_model_role": {
    "description": "片段阅读使用的模型角色。",
    "type": "string",
    "options": ["cheap", "quality", "current_session", "default"],
    "default": "cheap"
  },
  "chapter_note_model_role": {
    "description": "章节总结使用的模型角色。",
    "type": "string",
    "options": ["cheap", "quality", "current_session", "default"],
    "default": "cheap"
  },
  "important_note_model_role": {
    "description": "重要内容使用的模型角色。",
    "type": "string",
    "options": ["cheap", "quality", "current_session", "default"],
    "default": "quality"
  },
  "final_review_model_role": {
    "description": "全书总结使用的模型角色。",
    "type": "string",
    "options": ["cheap", "quality", "current_session", "default"],
    "default": "quality"
  },
  "memory_note_model_role": {
    "description": "记忆沉淀使用的模型角色。",
    "type": "string",
    "options": ["cheap", "quality", "current_session", "default"],
    "default": "quality"
  },
  "pro_upgrade_importance_threshold": {
    "description": "升级高质量模型的阈值。",
    "type": "float",
    "default": 0.75
  },
  "enable_deeper_review": {
    "description": "启用重要内容复核。",
    "type": "bool",
    "default": true
  },
  "max_deeper_reviews_per_chapter": {
    "description": "每章最多复核次数。",
    "type": "int",
    "default": 3
  },
  "webui_enabled": {
    "description": "启用管理页面。",
    "type": "bool",
    "default": true
  },
  "webui_upload_enabled": {
    "description": "允许页面上传书籍。",
    "type": "bool",
    "default": true
  },
  "webui_max_upload_mb": {
    "description": "单本上传大小上限，单位 MB。",
    "type": "int",
    "default": 10
  },
  "webui_allow_book_delete": {
    "description": "允许删除或归档书籍。",
    "type": "bool",
    "default": false
  },
  "webui_notes_export_enabled": {
    "description": "允许导出阅读笔记。",
    "type": "bool",
    "default": true
  }
}
